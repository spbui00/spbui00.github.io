
# Ignore files generated by IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.komodoproject
*.komodotools

# Ignore Node.js dependencies
node_modules/

# Ignore build artifacts
dist/
build/
out/

# Ignore cache and log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment-specific files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore compiled CSS
*.css

# Ignore compiled JavaScript
*.js

# Ignore compiled SCSS
*.scss

# Ignore image thumbnails
*.thumb

# Ignore DS_Store files (macOS)
.DS_Store

# Ignore Thumbs.db files (Windows)
Thumbs.db
